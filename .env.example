# ══════════════════════════════════════════════════════════════════
#  .env — Alpaca API Credentials
#  Copy this file to .env and fill in your keys.
#  NEVER commit .env (it is in .gitignore)
# ══════════════════════════════════════════════════════════════════

# ── Account 1: Wheel Strategy (wheel.py) ──────────────────────────
WHEEL_ALPACA_API_KEY=your_wheel_api_key_here
WHEEL_ALPACA_API_SECRET=your_wheel_api_secret_here

# ── Account 2: Trailing Stop Strategy (trailing_stop.py) ──────────
TRAILING_ALPACA_API_KEY=your_trailing_api_key_here
TRAILING_ALPACA_API_SECRET=your_trailing_api_secret_here

# ── Account 3: Capitol Copier (capitol_copier/bot.py) ─────────────
CAPITOL_ALPACA_API_KEY=your_capitol_api_key_here
CAPITOL_ALPACA_API_SECRET=your_capitol_api_secret_here
